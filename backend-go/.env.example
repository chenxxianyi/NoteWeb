# NoteWeb Backend (Go)

# App
APP_NAME=NoteWeb API
ENV=development
DEBUG=true
PORT=8000
SECRET_KEY=change-me-in-production-noteweb-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (sqlite or mysql)
DB_DRIVER=sqlite
DB_PATH=./noteweb.db

# MySQL (used when DB_DRIVER=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=noteweb

# Upload
MAX_UPLOAD_SIZE=52428800
