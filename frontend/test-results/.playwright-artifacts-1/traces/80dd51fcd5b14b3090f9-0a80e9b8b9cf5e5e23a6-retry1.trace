336c5134] { position: relative;\n}\n.topbar__search input[data-v-336c5134] {\r\n  font-family: var(--font-ui); font-size: 0.85rem; padding: 0.5rem 0.8rem 0.5rem 2.2rem;\r\n  border: 1px solid var(--border-color); border-radius: 20px; background: var(--bg-card);\r\n  color: var(--text-primary); outline: none; width: 200px; transition: border-color 0.15s;\n}\n.topbar__search input[data-v-336c5134]:focus { border-color: var(--accent);\n}\n.topbar__search input[data-v-336c5134]::placeholder { color: var(--text-muted);\n}\n.search-icon[data-v-336c5134] { position: absolute; left: 0.7rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);\n}\n.upload-btn[data-v-336c5134] { display: flex; align-items: center; gap: 0.4rem; padding: 0.4rem 0.9rem 0.4rem 0.6rem; border: 1px solid var(--border-color); border-radius: 20px; background: var(--bg-card); font-family: var(--font-ui); font-size: 0.8rem; color: var(--text-secondary); cursor: pointer; transition: all 0.15s;\n}\n.upload-btn[data-v-336c5134]:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light);\n}\n.upload-btn svg[data-v-336c5134] { width: 16px; height: 16px;\n}\r\n\r\n/* Weekly Overview */\n.weekly-overview[data-v-336c5134] { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 1.5rem 2rem; margin-bottom: 1.5rem;\n}\n.weekly-overview__header[data-v-336c5134] { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;\n}\n.weekly-overview__header h2[data-v-336c5134] { font-family: var(--font-display); font-size: 1.1rem; font-weight: 500; color: var(--text-primary);\n}\n.weekly-overview__grid[data-v-336c5134] { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;\n}\n.wo-item[data-v-336c5134] { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 0.75rem; border-radius: 8px; transition: background 0.15s;\n}\n.wo-item[data-v-336c5134]:hover { background: var(--acce